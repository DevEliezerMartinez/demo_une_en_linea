---
/**
 * LICENCIATURA EN ADMINISTRACIÓN
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/administracion-13.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/administracion-14.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("administracion");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Administración | UNE - Liderazgo y Estrategia"
  description="Estudia Administración en UNE. Desarrolla habilidades directivas, gestión de talento y visión empresarial con validez oficial RVOE."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Licenciatura en Administración <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Conviértete en el líder que las organizaciones modernas demandan.
              Aprende a gestionar recursos, optimizar procesos y tomar
              decisiones estratégicas que impulsen la rentabilidad y el
              crecimiento.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>💼 Gestión Empresarial</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🌱 Emprendimiento</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              IMPULSA TU FUTURO DIRECTIVO
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Ejecutivo</a>
            <a href="#requisitos" class="hover:underline">Requisitos</a>
            <a href="#plan-estudios" class="hover:underline">Materias</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Administrador analizando indicadores de rendimiento"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Visión Directiva de Alto Impacto"
      descripcion="La administración es la columna vertebral de cualquier éxito empresarial. En UNE te formamos para entender la organización como un todo, capacitándote para coordinar equipos multidisciplinarios hacia objetivos comunes y sostenibles."
      tituloSeccion="¿Qué serás capaz de lograr?"
      aprendizaje="Desarrollarás un perfil integral para: Diseñar modelos de negocio innovadores, gestionar el capital humano con sentido ético, aplicar análisis financieros para la rentabilidad y liderar procesos de transformación organizacional."
      imagenSrc={CarreraImg}
      imagenAlt="Líder empresarial dirigiendo reunión estratégica"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="¿Por qué Administración en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LAV_Administracion_PLN_BRCH/"
      benefits={[
        "Enfoque práctico en gestión de pymes y grandes corporativos.",
        "Desarrollo de habilidades blandas y liderazgo efectivo.",
        "Docentes con amplia experiencia en cargos gerenciales.",
        "Modelo flexible ideal para quienes ya trabajan.",
      ]}
      outcomes={[
        "Dirige áreas administrativas en empresas de cualquier sector.",
        "Lanza y gestiona tu propio modelo de negocio.",
        "Desempeñate como consultor en procesos de calidad.",
        "Especialízate en recursos humanos, finanzas u operaciones.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Lidera el cambio en el mundo de los negocios"
      subtitle="Adquiere las competencias gerenciales para destacar en un mercado competitivo. ¡Inscríbete hoy!"
      backgroundImage={true}
    />
  </main>
</Layout>
