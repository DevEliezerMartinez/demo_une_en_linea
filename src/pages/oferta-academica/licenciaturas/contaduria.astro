---
/**
 * LICENCIATURA EN CONTADURÍA
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/contaduria-18.webp";
import BachilleratoImg from "@/assets/imagenes/cards_licenciaturas/contaduria-19.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnContaduria");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Contaduría | UNE - Excelencia en Finanzas"
  description="Estudia Contaduría en UNE. Domina la gestión financiera, fiscal y de auditoría con nuestro programa ejecutivo con validez oficial."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Licenciatura en Contaduría <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Conviértete en la pieza clave de la estabilidad empresarial.
              Aprende a gestionar recursos, optimizar impuestos y liderar la
              salud financiera de organizaciones nacionales e internacionales.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📊 Auditoría y Fiscal</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>💰 Estrategia Financiera</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              IMPULSAR MI PERFIL FINANCIERO
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Contable</a>
            <a href="#requisitos" class="hover:underline">Requisitos</a>
            <a href="#plan-estudios" class="hover:underline">Plan de Estudios</a
            >
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Contador analizando estados financieros en entorno ejecutivo"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Visión Integral de los Negocios"
      descripcion="El contador moderno es mucho más que un gestor de números; es un asesor estratégico. En UNE te preparamos para interpretar la información financiera y convertirla en una ventaja competitiva para el crecimiento de las empresas."
      tituloSeccion="¿Qué competencias dominarás?"
      aprendizaje="Estarás capacitado para: Elaborar y auditar estados financieros, diseñar estrategias de planeación fiscal, gestionar costos y presupuestos, y aplicar las normas de información financiera (NIF) vigentes con ética y precisión."
      imagenSrc={BachilleratoImg}
      imagenAlt="Equipo contable en revisión de estrategia corporativa"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea / Diseñada para Trabajadores"
      benefitsLabel="¿Por qué Contaduría en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LCV_Contaduria_PLN_BRCH"
      benefits={[
        "Enfoque en las últimas reformas fiscales y normativas.",
        "Uso de software contable y herramientas digitales.",
        "Docentes con sólida experiencia en despachos y empresas.",
        "Flexibilidad total para equilibrar estudio y trabajo.",
      ]}
      outcomes={[
        "Lidera departamentos de contabilidad y finanzas.",
        "Emprende tu propia firma de consultoría contable.",
        "Especialízate en auditoría corporativa o peritaje.",
        "Asesora estratégicamente en materia de impuestos.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Toma el control de tu futuro profesional"
      subtitle="La transparencia y eficiencia financiera son el motor de la economía. ¡Sé parte del cambio hoy mismo!"
      backgroundImage={true}
    />
  </main>
</Layout>
