---
/**
 * LICENCIATURA EN MERCADOTECNIA
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/mercadotecnia-20.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/mercadotecnia-21.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnMercadotecnia");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Mercadotecnia | UNE - Estrategia y Creatividad"
  description="Domina el mercado digital y tradicional con nuestra Licenciatura en Mercadotecnia. Aprende estrategias de marca, ventas y análisis de mercado."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Licenciatura en Mercadotecnia <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Conviértete en el estratega que las marcas necesitan. Aprende a
              conectar productos con consumidores mediante campañas innovadoras,
              análisis de datos y una visión comercial global.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🚀 Enfoque Digital</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📊 Análisis de Datos</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              IMPULSAR MI CARRERA
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Estratégico</a>
            <a href="#requisitos" class="hover:underline">Documentación</a>
            <a href="#plan-estudios" class="hover:underline">Plan de Estudios</a
            >
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Estratega de marketing trabajando en analítica"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Lidera las tendencias del mercado"
      descripcion="Ya no basta con vender; hay que generar experiencias. Nuestra formación te dota de herramientas para entender la psicología del consumidor y dominar los canales digitales más relevantes del mundo actual."
      tituloSeccion="¿Qué serás capaz de hacer?"
      aprendizaje="Desarrollarás una mentalidad competitiva para: Diseñar planes de marketing integral, gestionar marcas de alto impacto (branding), ejecutar campañas de publicidad digital y analizar métricas para maximizar la rentabilidad de cualquier negocio."
      imagenSrc={CarreraImg}
      imagenAlt="Equipo de marketing colaborando en estrategia"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea / Flexibilidad Total"
      benefitsLabel="¿Por qué estudiar Mercadotecnia en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LMV_Mercadotecnia_PLN_BRCH"
      benefits={[
        "Contenido actualizado a la era del E-commerce.",
        "Proyectos prácticos basados en casos reales.",
        "Networking con profesionales del sector comercial.",
        "Certificación oficial para un crecimiento inmediato.",
      ]}
      outcomes={[
        "Lidera departamentos de marketing y comunicación.",
        "Crea tu propia agencia o consultoría de branding.",
        "Domina el posicionamiento de productos y servicios.",
        "Especialízate en investigación de mercados y tendencias.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="El futuro de las marcas está en tus manos"
      subtitle="Adquiere las competencias necesarias para destacar en un mercado global competitivo. ¡Inscríbete hoy!"
      backgroundImage={true}
    />
  </main>
</Layout>
