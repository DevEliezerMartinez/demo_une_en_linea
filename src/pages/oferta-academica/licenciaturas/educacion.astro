---
/**
 * LICENCIATURA EN EDUCACIÓN
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/educacion-30.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/educacion-31.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnEducacion");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Educación | UNE - Transforma el Futuro"
  description="Estudia la Licenciatura en Educación en UNE. Fórmate como un experto en pedagogía, diseño curricular y gestión educativa con validez oficial."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Licenciatura en Educación <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Conviértete en el agente de cambio que la sociedad necesita.
              Domina las nuevas tecnologías aplicadas a la enseñanza y
              desarrolla estrategias pedagógicas para inspirar a las próximas
              generaciones.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🎓 Innovación Pedagógica</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>💻 Tecnologías Educativas</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              QUIERO SER EDUCADOR
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil de Egreso</a>
            <a href="#requisitos" class="hover:underline">Inscripciones</a>
            <a href="#plan-estudios" class="hover:underline">Materias</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Educador diseñando estrategias de enseñanza en un entorno digital"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Liderazgo para la Transformación Social"
      descripcion="Educar no es solo transmitir información, es formar seres humanos capaces. Nuestra licenciatura te brinda las herramientas para entender los procesos de aprendizaje desde la neurociencia hasta la sociología educativa."
      tituloSeccion="¿Qué competencias desarrollarás?"
      aprendizaje="Estarás preparado para: Diseñar y evaluar planes de estudio innovadores, gestionar instituciones educativas de alto nivel, aplicar modelos de enseñanza inclusiva y dominar entornos virtuales de aprendizaje (e-learning)."
      imagenSrc={CarreraImg}
      imagenAlt="Docente colaborando con un equipo multidisciplinario"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea / Flexibilidad Laboral"
      benefitsLabel="¿Por qué Educación en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LCE_Educacion_PLN_BRCH"
      benefits={[
        "Fuerte enfoque en la práctica docente actual.",
        "Metodologías de enseñanza para el siglo XXI.",
        "Compatibilidad total con tu horario de trabajo.",
        "Reconocimiento oficial para plazas y cargos directivos.",
      ]}
      outcomes={[
        "Dirige departamentos de capacitación empresarial.",
        "Desempeñate como docente en diversos niveles educativos.",
        "Asesora proyectos de diseño curricular y pedagogía.",
        "Lidera consultorías en psicopedagogía y desarrollo humano.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Tu vocación merece una formación de excelencia"
      subtitle="Únete a la nueva generación de profesionales que están rediseñando el aprendizaje en México."
      backgroundImage={true}
    />
  </main>
</Layout>
