---
/**
 * LICENCIATURA EN DISEÑO GRÁFICO
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/diseno_grafico-34.webp";
import carreraImg from "@/assets/imagenes/cards_licenciaturas/diseno_grafico-35.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnDisenoGrafico");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Diseño Gráfico | UNE - Creatividad que Impacta"
  description="Estudia Diseño Gráfico en UNE. Domina las herramientas digitales, el branding y la comunicación visual con validez oficial RVOE."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Licenciatura en Diseño Gráfico <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Transforma ideas en soluciones visuales impactantes. Domina el
              arte de la comunicación, la identidad de marca y las plataformas
              digitales para liderar la industria creativa actual.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🎨 Branding & Identidad</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>💻 Diseño Digital y UX</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              QUIERO SER DISEÑADOR
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Creativo</a>
            <a href="#requisitos" class="hover:underline">Admisión</a>
            <a href="#plan-estudios" class="hover:underline">Mapa Curricular</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Diseñador trabajando en tableta digital y software profesional"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Domina el Lenguaje de las Ideas"
      descripcion="El diseño gráfico moderno va más allá de 'hacer cosas bonitas'; se trata de resolver problemas complejos de comunicación. En UNE te enseñamos a conceptualizar y ejecutar proyectos que capturen la atención en un mundo saturado de imágenes."
      tituloSeccion="¿Qué lograrás con nosotros?"
      aprendizaje="Serás un experto capaz de: Crear sistemas de identidad visual potentes, dominar la suite profesional de diseño, gestionar proyectos editoriales y de empaque, y aplicar principios de diseño interactivo para la web y redes sociales."
      imagenSrc={carreraImg}
      imagenAlt="Proyectos de diseño gráfico y conceptualización visual"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea / Flexibilidad Creativa"
      benefitsLabel="¿Por qué estudiar Diseño en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LDG_Disenografico_PLN_BRCH"
      benefits={[
        "Enfoque práctico en proyectos reales desde el inicio.",
        "Docentes inmersos en el mundo de la publicidad y el arte.",
        "Aprende a monetizar tu talento como freelance o agencia.",
        "Certificación oficial que respalda tu capacidad técnica.",
      ]}
      outcomes={[
        "Lidera departamentos de arte en agencias de publicidad.",
        "Emprende tu propio estudio de diseño o branding.",
        "Especialízate en diseño de experiencia de usuario (UI/UX).",
        "Gestiona la comunicación visual de marcas internacionales.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Convierte tu visión en tu profesión"
      subtitle="El mundo necesita diseñadores con propósito. Da el primer paso para crear el futuro visual."
      backgroundImage={true}
    />
  </main>
</Layout>
