---
/**
 * INGENIERÍA INDUSTRIAL
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/ingenieria_industrial-24.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/ingenieria_industrial-25.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("ingenieriaIndustrial");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Ingeniería Industrial | UNE - Optimiza y Lidera Procesos"
  description="Estudia Ingeniería Industrial en UNE. Especialízate en optimización de procesos, gestión de calidad y sistemas de producción con validez oficial."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Ingeniería Industrial <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Diseña, mejora e instala sistemas integrados de personas,
              materiales y tecnología. Fórmate como el ingeniero capaz de
              maximizar la productividad y eficiencia en cualquier sector
              industrial.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>⚙️ Gestión de Calidad</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📈 Optimización Operativa</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INICIAR MI FORMACIÓN
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>
          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil de Ingeniería</a>
            <a href="#requisitos" class="hover:underline">Admisión</a>
            <a href="#plan-estudios" class="hover:underline">Mapa Curricular</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Ingeniero industrial supervisando procesos de producción"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Liderazgo en la Cadena de Valor"
      descripcion="La industria moderna exige ingenieros que no solo entiendan las máquinas, sino también la gestión del talento y los recursos financieros. Nuestra metodología te prepara para ser un motor de rentabilidad y sostenibilidad."
      tituloSeccion="¿Qué objetivos alcanzarás?"
      aprendizaje="Desarrollarás un perfil analítico para: Implementar sistemas de manufactura esbelta (Lean), gestionar cadenas de suministro globales, asegurar estándares de calidad internacional y liderar proyectos de ingeniería con enfoque en la seguridad y el medio ambiente."
      imagenSrc={CarreraImg}
      imagenAlt="Planta industrial y sistemas de control"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="¿Por qué Ingeniería Industrial en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/IND_IngenieriaIndustrial_PLN_BRCH"
      benefits={[
        "Fuerte enfoque en administración y finanzas industriales.",
        "Laboratorios virtuales y herramientas de simulación.",
        "Catedráticos activos en los principales sectores industriales.",
        "Modelo flexible para quienes ya trabajan en planta.",
      ]}
      outcomes={[
        "Ocupa puestos directivos en el sector manufacturero.",
        "Especialízate en logística y operaciones de alto nivel.",
        "Gestiona consultorías de mejora continua y procesos.",
        "Domina la normativa nacional e internacional de seguridad.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Conviértete en el motor de la productividad"
      subtitle="El mundo industrial busca tu talento para diseñar los sistemas del mañana. ¡Empieza hoy mismo!"
      backgroundImage={true}
    />
  </main>
</Layout>
