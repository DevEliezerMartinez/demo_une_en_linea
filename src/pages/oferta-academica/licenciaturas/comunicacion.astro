---
/**
 * LICENCIATURA EN COMUNICACIÓN
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/comunicacion-26.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/comunicacion-27.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnComunicacion");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Comunicación | UNE - Conecta y Transmite"
  description="Estudia Comunicación en UNE. Domina la producción de medios, periodismo digital y comunicación organizacional con validez oficial RVOE."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Licenciatura en Comunicación <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Domina el arte de conectar audiencias. Aprende a crear narrativas
              poderosas, gestionar medios digitales y liderar la opinión pública
              en la era de la información.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🎙️ Producción de Medios</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📱 Estrategia Digital</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              HAZ QUE TU VOZ SE ESCUCHE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Profesional</a>
            <a href="#requisitos" class="hover:underline">Admisión</a>
            <a href="#plan-estudios" class="hover:underline">Mapa Curricular</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Comunicador en set de producción multimedia"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Liderazgo en la Era del Contenido"
      descripcion="Comunicar hoy requiere más que solo hablar; exige estrategia, ética y dominio técnico. En UNE te formamos para entender el impacto de los mensajes en la sociedad y utilizar las herramientas multimedia para generar cambios reales."
      tituloSeccion="¿Qué habilidades desarrollarás?"
      aprendizaje="Serás un comunicador versátil capaz de: Producir contenidos audiovisuales de alta calidad, gestionar la reputación de marcas, redactar crónicas y reportajes para medios digitales, y diseñar planes de comunicación interna para organizaciones corporativas."
      imagenSrc={CarreraImg}
      imagenAlt="Equipo de comunicación en sala de redacción digital"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="¿Por qué Comunicación en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LMC_Comunicacion_PLN_BRCH"
      benefits={[
        "Enfoque en nuevas plataformas y redes sociales.",
        "Prácticas en producción de radio, video y podcast.",
        "Formación en relaciones públicas y manejo de crisis.",
        "Docentes expertos en la industria mediática actual.",
      ]}
      outcomes={[
        "Dirige agencias de contenido y relaciones públicas.",
        "Desarróllate como periodista o locutor en medios masivos.",
        "Coordina la comunicación corporativa en empresas globales.",
        "Gestiona campañas de marketing político y social.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Conecta con el mundo a través de tus ideas"
      subtitle="El futuro de la comunicación se está escribiendo ahora. ¡Sé el protagonista de esta historia!"
      backgroundImage={true}
    />
  </main>
</Layout>
