---
/**
 * LICENCIATURA EN COMERCIO Y NEGOCIOS GLOBALES
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/comercio_negocios.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/comercio_y_negocios_globales.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnComercioYNegociosGlobales");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Comercio y Negocios Globales | UNE - Conecta con el Mundo"
  description="Estudia Comercio y Negocios Globales en UNE. Especialízate en logística internacional, aduanas y tratados comerciales con validez oficial."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Comercio y Negocios Globales <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Lleva las fronteras de los negocios más allá de los límites.
              Domina las cadenas de suministro globales, las leyes aduaneras y
              la diplomacia comercial para liderar la economía internacional.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🌎 Logística Internacional</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>⚖️ Aduanas y Aranceles</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              EMPEZAR A EXPANDIR MIS HORIZONTES
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRIBIRME
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Global</a>
            <a href="#requisitos" class="hover:underline">Inscripción</a>
            <a href="#plan-estudios" class="hover:underline">Plan de Estudios</a
            >
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Estratega de negocios globales analizando rutas comerciales"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Estrategia sin Fronteras"
      descripcion="El comercio global demanda expertos capaces de navegar en la complejidad de los mercados internacionales. En UNE te formamos para identificar oportunidades de inversión y gestionar la operatividad del comercio exterior con eficiencia y visión estratégica."
      tituloSeccion="¿Qué lograrás con nosotros?"
      aprendizaje="Serás un profesional capaz de: Ejecutar procesos de importación y exportación, gestionar logística internacional y transporte, analizar tratados de libre comercio y diseñar estrategias de internacionalización para empresas de todos los tamaños."
      imagenSrc={CarreraImg}
      imagenAlt="Logística y puertos comerciales internacionales"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="¿Por qué estudiar Negocios Globales en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LCN_ComercioYNegociosGlobales_PLN_BRCH"
      benefits={[
        "Enfoque práctico en leyes y tramitología aduanera.",
        "Análisis real de mercados emergentes y globales.",
        "Docentes con experiencia activa en comercio exterior.",
        "Modelo diseñado para integrarte rápido al sector logístico.",
      ]}
      outcomes={[
        "Dirige agencias aduanales y empresas de logística.",
        "Lidera áreas de compras internacionales y supply chain.",
        "Asesora empresas en su expansión a mercados extranjeros.",
        "Colabora en organismos gubernamentales de fomento al comercio.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="El mercado global espera por ti"
      subtitle="Adquiere las competencias necesarias para conectar mercados y potenciar el comercio mundial."
      backgroundImage={true}
    />
  </main>
</Layout>
