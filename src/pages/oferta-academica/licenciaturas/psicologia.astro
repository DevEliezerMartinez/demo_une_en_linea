---
/**
 * LICENCIATURA EN PSICOLOGÍA
 * Página de oferta académica
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/psicologia-32.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/psicologia-33.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("licenciaturaEnPsicologia");
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Psicología | UNE - Modalidad Flexible"
  description="Conviértete en un profesional de la salud mental con nuestra Licenciatura en Psicología. Formación integral con validez oficial RVOE."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Tu Licenciatura en Psicología <span
                class="text-azul-une block md:inline italic">UNE</span
              > con Validez Oficial
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Comprende el comportamiento humano y transforma vidas. Un programa
              diseñado para formarte como un profesional de la salud mental con
              la flexibilidad que necesitas para equilibrar tu vida personal y
              profesional.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📚 Modalidad en línea</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🧠 Enfoque Clínico y Social</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              QUIERO SER PSICOLOGO
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil de Egreso</a>
            <a href="#requisitos" class="hover:underline">Inscripción</a>
            <a href="#plan-estudios" class="hover:underline">Plan de Estudios</a
            >
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Estudiante analizando material de psicología"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Impacta positivamente en tu comunidad"
      descripcion="La psicología no es solo teoría; es la capacidad de observar, diagnosticar y proponer soluciones a los retos del bienestar emocional contemporáneo. Nuestro modelo te prepara para intervenir en diversos ámbitos con ética y responsabilidad."
      tituloSeccion="¿Cuál es tu potencial?"
      aprendizaje="Dominarás las bases del comportamiento humano para: Realizar evaluaciones psicológicas precisas, diseñar estrategias de intervención clínica, aplicar técnicas de diagnóstico y liderar procesos de cambio en entornos organizacionales y sociales."
      imagenSrc={CarreraImg}
      imagenAlt="Profesionales de la salud mental en sesión"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="Ventajas de estudiar en UNE"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LPS_Psicologia_PLN_BRCH"
      benefits={[
        "Docentes con amplia experiencia clínica y laboral.",
        "Plan de estudios actualizado a las necesidades actuales.",
        "Horarios diseñados para personas que trabajan.",
        "Vinculación con instituciones de salud y sociales.",
      ]}
      outcomes={[
        "Podrás ejercer en el ámbito clínico, educativo u organizacional.",
        "Desarrollarás habilidades de escucha activa y empatía profesional.",
        "Contarás con las bases para realizar investigación psicológica.",
        "Obtendrás un título con validez oficial para tramitar tu cédula.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Inicia tu camino en las Ciencias del Comportamiento"
      subtitle="La sociedad necesita profesionales preparados. Convierte tu vocación en tu profesión hoy mismo."
      backgroundImage={true}
    />
  </main>
</Layout>
