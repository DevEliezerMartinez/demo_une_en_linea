---
/**
 * ADMINISTRACIÓN DE SISTEMAS DE INFORMACIÓN
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/administracion_de_sistemas_de_informacion-15.webp";
import CarreraImg from "@/assets/imagenes/cards_licenciaturas/administracion_de_sistemas_de_informacion-17.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI/Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios(
  "licenciaturaEnAdministracionDeSistemasDeLaInformacion",
);
const infoActual = obtenerDatos("licenciatura");
const listaRequisitos = obtenerRequisitos();
const linkPdf = "/requisitos/licenciatura.pdf";
---

<Layout
  title="Licenciatura en Administración de Sistemas de Información | UNE"
  description="Estudia Administración de Sistemas de Información en UNE. Lidera la transformación digital, gestiona bases de datos y redes con validez oficial."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Admón. de Sistemas de Información <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Conviértete en el puente entre la tecnología y los negocios.
              Domina la infraestructura digital, la ciberseguridad y la
              analítica de datos para potenciar la competitividad empresarial.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>💻 Gestión TI</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🔒 Ciberseguridad</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              LIDERA EL FUTURO DIGITAL
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Tecnológico</a>
            <a href="#requisitos" class="hover:underline">Requisitos</a>
            <a href="#plan-estudios" class="hover:underline">Materias TI</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Administrador de sistemas analizando infraestructura de datos"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Estrategia Tecnológica para el Mundo Real"
      descripcion="Hoy en día, ninguna empresa sobrevive sin una infraestructura de información sólida. En UNE te formamos para administrar, proteger y optimizar los activos digitales de cualquier organización, alineando la tecnología con los objetivos financieros."
      tituloSeccion="¿Qué competencias dominarás?"
      aprendizaje="Estarás capacitado para: Administrar bases de datos y redes de comunicación, implementar protocolos de ciberseguridad empresarial, gestionar proyectos de transformación digital y liderar departamentos de soporte técnico y TI."
      imagenSrc={CarreraImg}
      imagenAlt="Especialista en TI trabajando con servidores y redes"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="10 Cuatrimestres"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="¿Por qué estudiar Sistemas en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LSV_AdminSistemDeInfo_PLN_BRCH"
      benefits={[
        "Enfoque en herramientas de gestión de TI actuales.",
        "Docentes activos en la industria tecnológica.",
        "Prácticas orientadas a soluciones empresariales reales.",
        "Certificación oficial para ascender en el área de TI.",
      ]}
      outcomes={[
        "Dirige áreas de Tecnologías de la Información.",
        "Emprende tu propia consultoría de soporte y redes.",
        "Especialízate en auditoría de sistemas e infraestructura.",
        "Gestiona la seguridad informática de grandes corporativos.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Sé el arquitecto de la era digital"
      subtitle="La demanda de expertos en sistemas nunca ha sido tan alta. ¡Inicia tu camino hoy mismo!"
      backgroundImage={true}
    />
  </main>
</Layout>
