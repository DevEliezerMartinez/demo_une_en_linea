---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets"; // Importante para optimizar imágenes en Astro
import HeroImg from "@/assets/imagenes/CardsNiveles/bachillerato_en_linea.webp"; // Usando tu variable
import BachilleratoImg from "@/assets/imagenes/CardsNiveles/bachillerato_en_linea-2.webp"; // Usando tu variable
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
const plan_bachillerato = obtenerPlanEstudios("bachillerato");
import Faq from "@/components/sections/shared/Faq.astro";
import { obtenerDatos } from "@/helpers/faq.js";
const infoActual = obtenerDatos("bachillerato");
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// Lista estructurada de requisitos para inscripción
const listaRequisitos = [
  {
    id: 1,
    label: "Acta de nacimiento",
    copies: 3,
    original: true,
    note: "Fecha de expedición no mayor a un año. En excelente estado. Puede descargarse en línea, imprimirse a color y en hoja opalina.",
    link: "https://actasenlinea.jalisco.gob.mx/actasescolares/Nacimiento.do",
  },
  {
    id: 2,
    label: "Certificado de secundaria",
    copies: 3,
    original: true,
    note: "Si fue expedido en otro estado distinto a Jalisco, debe estar legalizado, salvo que incluya la leyenda de validez nacional.",
  },
  {
    id: 3,
    label: "Carta de validación del certificado de secundaria",
    copies: 3,
    original: true,
    note: "Documento obligatorio. Sin esta carta, el certificado no es válido y no se acepta para la inscripción ante secretaría. Debe estar dirigida a quien corresponda o a la Mtra. Fanny Guadalupe Valdivia Márquez, Directora de Incorporación y Servicios Escolares SICyT. Debe presentarse en hoja membretada e incluir folio del certificado, nombre del alumno y fecha de expedición.",
  },
  {
    id: 4,
    label: "CURP",
    copies: 3,
    original: false,
    note: "Copia legible.",
  },
  {
    id: 5,
    label: "Identificación oficial vigente con fotografía",
    copies: 3,
    original: false,
    note: "Debe estar vigente.",
  },
  {
    id: 6,
    label: "Comprobante de domicilio",
    copies: 3,
    original: false,
    note: "Comprobante reciente.",
  },
  {
    id: 7,
    label: "Fotografías tamaño infantil blanco y negro",
    quantity: 8,
    original: true,
    note: "Vestimenta presentable. Pueden ser de Farmacia Guadalajara.",
  },
  {
    id: 8,
    label: "Fotografías tamaño credencial a color",
    quantity: 2,
    original: true,
    note: "Vestimenta presentable. Pueden ser de Farmacia Guadalajara.",
  },
];

const linkPdf = "/requisitos/bachillerato.pdf"; // Ruta a tu PDF
---

<Layout
  title="Bachillerato en Línea | UNE - Termina tu Prepa"
  description="Estudia tu Bachillerato 100% en línea con validez oficial SEJ. Horarios flexibles y plataforma 24/7. ¡Inscríbete hoy!"
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Tu Bachillerato <span class="text-azul-une block md:inline italic"
                >UNE</span
              > con Validez Oficial
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Termina tu prepa 100% en línea sin descuidar tu trabajo o familia.
              Un modelo flexible diseñado para que logres tu certificado y des
              el salto a la universidad.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📚 Termina en 2 años 8 meses</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>💻 Plataforma 24/7</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓SEJ Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col sm:flex-row gap-4 items-center">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              Contacta a UNE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">¿Por qué UNE?</a>
            <a href="#requisitos" class="hover:underline">Requisitos</a>
            <a href="#plan-estudios" class="hover:underline">Materias</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Estudiante joven usando laptop felizmente"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    {/* Aquí corregimos el error de "Administrador" y el texto denso */}
    <Proposito_competencias
      titulo="Prepárate para el mundo real"
      descripcion="Olvídate de la memorización vacía. Nuestro enfoque te da herramientas prácticas para desenvolverte con seguridad en la vida laboral, social y digital actual. No solo obtienes un papel, desarrollas tu criterio propio."
      tituloSeccion="¿Qué vas a lograr?"
      aprendizaje="Convertirte en un estudiante autónomo capaz de: Aprender a aprender (gestionar tu propio conocimiento), comunicarse efectivamente en entornos digitales, trabajar en equipo a distancia y desarrollar un pensamiento crítico para la solución de problemas reales."
      imagenSrc={BachilleratoImg}
      imagenAlt="Estudiantes de bachillerato colaborando"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="2 años 8 meses"
      modeLabel="Modalidad"
      mode="100% en línea"
      benefitsLabel="¿Por qué elegirnos?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/BV_Bachillerato_PLN_BRCH/index.html"
      benefits={[
        "Tú decides tus horarios: plataforma abierta 24/7.",
        "Acompañamiento real: tutores que resuelven tus dudas.",
        "Sin gastos de traslado: estudia desde tu casa.",
        "Certificado SEJ válido en cualquier universidad.",
      ]}
      outcomes={[
        " Construir una base sólida para tu carrera universitaria.",
        "Mejorar tu perfil laboral y aspirar a ascensos.",
        "Desarrollar disciplina digital y autogestión.",
        "Fomentar valores éticos y responsabilidad social.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan_bachillerato} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Tu certificado de prepa está a un clic de distancia"
      subtitle="Deja de postergar tu futuro. Inscríbete hoy y da el paso que cambiará tu vida profesional."
      backgroundImage={true}
    />
  </main>
</Layout>
