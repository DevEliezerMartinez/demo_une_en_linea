---
/**
 * MAESTRÍA EN ADMINISTRACIÓN DE NEGOCIOS
 * Página de oferta académica (Posgrado)
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/administracion-13.webp";
import BachilleratoImg from "@/assets/imagenes/cards_licenciaturas/administracion-14.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("maestriaEnAdministracionDeNegocios");
const infoActual = obtenerDatos("maestria");
const listaRequisitos = obtenerRequisitos("maestria");
const linkPdf = "/requisitos/posgrado.pdf";
---

<Layout
  title="Maestría en Administración de Negocios (MBA) | UNE - Alta Dirección"
  description="Lleva tu carrera al nivel ejecutivo con el MBA de UNE. Especialízate en finanzas corporativas, liderazgo estratégico y gestión de negocios globales."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Maestría en Admón. de Negocios <span
                class="text-azul-une block md:inline italic">MBA</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Desarrolla la visión global y las competencias directivas
              necesarias para liderar organizaciones en entornos complejos. El
              posgrado diseñado para los tomadores de decisiones del mañana.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>📈 Finanzas Avanzadas</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>👑 Liderazgo Directivo</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Federal Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              QUIERO SER LIDER
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil Ejecutivo</a>
            <a href="#requisitos" class="hover:underline">Admisión Posgrado</a>
            <a href="#plan-estudios" class="hover:underline">Mapa Curricular</a>
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Directivo analizando métricas de crecimiento empresarial"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Pensamiento Estratégico de Clase Mundial"
      descripcion="Este MBA trasciende la gestión operativa para enfocarse en la creación de valor. En UNE te preparamos para analizar mercados globales, optimizar estructuras financieras y liderar la innovación en modelos de negocio."
      tituloSeccion="¿Qué habilidades potenciarás?"
      aprendizaje="Estarás capacitado para: Diseñar estrategias competitivas de largo plazo, gestionar finanzas corporativas complejas, liderar procesos de negociación internacional y dirigir equipos de alto rendimiento bajo presión."
      imagenSrc={BachilleratoImg}
      imagenAlt="Reunión de consejo directivo y planeación estratégica"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="1 año 8 meses (5 Cuatrimestres)"
      modeLabel="Modalidad"
      mode="En línea / Formato de Alta Flexibilidad"
      benefitsLabel="¿Por qué cursar el MBA en UNE?"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/MAV_AdmidNeg_PLN_BRCH"
      benefits={[
        "Networking con profesionales de diversos sectores industriales.",
        "Casos de estudio enfocados en la realidad empresarial actual.",
        "Catedráticos con puestos directivos en empresas globales.",
        "Estructura curricular alineada a la economía digital.",
      ]}
      outcomes={[
        "Accede a cargos de Dirección General (CEO) o Finanzas (CFO).",
        "Escala tus proyectos de emprendimiento a nivel corporativo.",
        "Desempeñate como consultor senior de negocios.",
        "Lidera la expansión internacional de organizaciones.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="El siguiente nivel de tu carrera te espera"
      subtitle="Obtén el grado que te posicionará en la cima de la jerarquía corporativa."
      backgroundImage={true}
    />
  </main>
</Layout>
