---
/**
 * MAESTRÍA EN EDUCACIÓN
 * Página de oferta académica (Posgrado)
 */

// 1. Layouts e Imágenes
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroImg from "@/assets/imagenes/cards_licenciaturas/administracion-13.webp";
import BachilleratoImg from "@/assets/imagenes/cards_licenciaturas/administracion-14.webp";

// 2. Componentes de la Sección (Oferta)
import Proposito_competencias from "@/components/sections/oferta/Propósito-competencias.astro";
import Detalles_Formacion from "@/components/sections/oferta/Detalles-Formación.astro";
import Requisitos from "@/components/sections/oferta/Requisitos.astro";
import Plan_estudios from "@/components/sections/oferta/Plan-estudios.astro";

// 3. Componentes Compartidos (UI / Globales)
import Faq from "@/components/sections/shared/Faq.astro";
import GeneralCTA from "@/components/sections/shared/GeneralCTA.astro";
import { ArrowRight } from "@lucide/astro";

// 4. Lógica de Datos y Helpers
import { obtenerPlanEstudios } from "@/helpers/planes_estudio.js";
import { obtenerDatos } from "@/helpers/faq.js";
import { obtenerRequisitos } from "@/helpers/listaRequisitos";

// 5. Inicialización de Variables y Constantes
const plan = obtenerPlanEstudios("maestriaEnEducacion");
const infoActual = obtenerDatos("maestria");
const listaRequisitos = obtenerRequisitos("maestria");
const linkPdf = "/requisitos/posgrado.pdf";
---

<Layout
  title="Maestría en Educación | UNE - Especialización y Liderazgo Académico"
  description="Eleva tu perfil profesional con la Maestría en Educación de UNE. Especialízate en gestión institucional, diseño curricular e investigación pedagógica."
>
  <main class="min-h-screen mx-auto py-12 lg:py-20">
    {/* Hero section */}
    <section class="max-w-7xl px-4 mx-auto md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-5xl lg:text-6xl text-gray-800 font-bold leading-tight"
            >
              Maestría en Educación <span
                class="text-azul-une block md:inline italic">UNE</span
              >
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed max-w-lg">
              Redefine el futuro del aprendizaje. Desarrolla competencias de
              alta dirección, innovación pedagógica e investigación para
              transformar los procesos educativos en instituciones públicas y
              privadas.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-700">
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🏛️ Gestión Institucional</span>
            </div>
            <div
              class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg"
            >
              <span>🔍 Investigación Educativa</span>
            </div>
            <div
              class="flex items-center gap-1 bg-green-50 px-3 py-1 rounded-lg text-green-700"
            >
              <span>✓ RVOE Posgrado Oficial</span>
            </div>
          </div>

          <div class="pt-2 flex flex-col gap-4 items-center md:items-start">
            <a
              href="/contacto/solicitarinformacion"
              class="group inline-flex items-center bg-azul-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              IMPULSAR MI CARRERA DOCENTE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>

            {/* Botón A/B Test - Inscríbete */}
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLScyrURKYXtsBliCbWEgFt0FJU0j2wYuOrqc6QooqnWQ4AVG8A/viewform"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full md:w-auto inline-flex items-center bg-rojo-une text-white font-bold py-3 px-8 rounded-full text-lg hover:bg-azul-une transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              INSCRÍBETE
              <ArrowRight
                class="h-6 w-6 ml-2 group-hover:translate-x-1 transition-transform"
              />
            </a>
          </div>

          <nav
            class="pt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A55A2] font-medium"
          >
            <a href="#objetivo" class="hover:underline">Perfil de Posgrado</a>
            <a href="#requisitos" class="hover:underline"
              >Requisitos de Ingreso</a
            >
            <a href="#plan-estudios" class="hover:underline">Plan de Estudios</a
            >
          </nav>
        </div>

        <div class="order-1 lg:order-2">
          <div class="relative overflow-hidden rounded-xl shadow-2xl">
            <Image
              src={HeroImg}
              alt="Profesional de la educación liderando un equipo de investigación"
              class="w-full h-auto object-cover aspect-[4/3]"
            />
          </div>
        </div>
      </div>
    </section>

    <Proposito_competencias
      titulo="Liderazgo para la Excelencia Académica"
      descripcion="Este posgrado profundiza en la gestión estratégica del conocimiento. En UNE te preparamos para ser un experto en la toma de decisiones, capaz de diseñar políticas educativas y modelos de evaluación de alto impacto."
      tituloSeccion="¿Qué objetivos alcanzarás?"
      aprendizaje="Desarrollarás una visión experta para: Evaluar y proponer reformas curriculares, liderar procesos de acreditación institucional, aplicar metodologías de investigación avanzada y diseñar estrategias de educación a distancia y entornos virtuales."
      imagenSrc={BachilleratoImg}
      imagenAlt="Maestrandos en debate sobre políticas educativas"
    />

    <Detalles_Formacion
      durationLabel="Duración"
      duration="1 año 8 meses (5 Cuatrimestres)"
      modeLabel="Modalidad"
      mode="En línea"
      benefitsLabel="Ventajas del Posgrado en UNE"
      brochureUrl="https://contenido.une-enlinea.com/web/brochure/LCE_Educacion_PLN_BRCH"
      benefits={[
        "Programa diseñado para el perfeccionamiento docente.",
        "Facilidad para obtener grado mediante excelencia académica.",
        "Docentes con grado de doctorado y amplia experiencia.",
        "Networking con directivos y líderes del sector educativo.",
      ]}
      outcomes={[
        "Accede a puestos de dirección y coordinación académica.",
        "Especialízate en consultoría de capacitación empresarial.",
        "Desarrolla proyectos de investigación educativa formal.",
        "Mejora tu escalafón y reconocimiento profesional.",
      ]}
    />

    <Requisitos requirements={listaRequisitos} pdfUrl={linkPdf} />

    <Plan_estudios blocks={plan} />

    <Faq faqs={infoActual} />

    <GeneralCTA
      title="Es momento de trascender profesionalmente"
      subtitle="Obtén el grado que te permitirá liderar el cambio en el sistema educativo nacional."
      backgroundImage={true}
    />
  </main>
</Layout>
